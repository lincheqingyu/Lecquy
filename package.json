{
  "name": "webclaw",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:frontend": "pnpm -F @webclaw/frontend dev",
    "dev:backend": "pnpm -F @webclaw/backend dev",
    "bundle:runtime": "node scripts/generate-runtime-bundle.mjs",
    "build": "pnpm -F @webclaw/shared build && pnpm -F @webclaw/frontend build && pnpm run bundle:runtime && pnpm -F @webclaw/backend build",
    "build:portable": "pnpm build && node scripts/prepare-portable-release.mjs",
    "build:sea": "pnpm build && node scripts/build-sea.mjs",
    "build:sea:all": "pnpm build && node scripts/build-sea.mjs macos-arm64 linux-arm64 windows-x64",
    "build:sea:macos-arm64": "pnpm build && node scripts/build-sea.mjs macos-arm64",
    "build:sea:linux-arm64": "pnpm build && node scripts/build-sea.mjs linux-arm64",
    "build:sea:windows": "pnpm build && node scripts/build-sea.mjs windows-x64",
    "build:sea:windows-x64": "pnpm build && node scripts/build-sea.mjs windows-x64",
    "build:frontend": "pnpm -F @webclaw/frontend build",
    "build:backend": "pnpm -F @webclaw/backend build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf node_modules dist && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "esbuild": "0.27.3",
    "postject": "1.0.0-alpha.6"
  },
  "packageManager": "pnpm@10.6.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
